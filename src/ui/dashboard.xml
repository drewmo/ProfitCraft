                                <Offset>
                                    <AbsDimension x="4" y="0"/>
                                </Offset>
                            </Anchor>
                        </Anchors>
                        <MaxLetters>
                            <AbsValue val="3"/>
                        </MaxLetters>
                        <Scripts>
                            <OnEnterPressed>
                                ProfitCraft_OnLevelFilterInputCommit();
                                this:ClearFocus();
                            </OnEnterPressed>
                            <OnEscapePressed>
                                this:ClearFocus();
                                ProfitCraft_RefreshLevelFilterInputs();
                            </OnEscapePressed>
                            <OnEditFocusLost>
                                ProfitCraft_OnLevelFilterInputCommit();
                            </OnEditFocusLost>
                            <OnLoad>
                                this:SetJustifyH("CENTER");
                            </OnLoad>
                        </Scripts>
                    </EditBox>
                    <FontString name="ProfitCraftLevelMaxLabel" inherits="GameFontNormalSmall" text="Max" justifyH="LEFT">
                        <Anchors>
                            <Anchor point="LEFT" relativeTo="ProfitCraftLevelMinInput" relativePoint="RIGHT">
