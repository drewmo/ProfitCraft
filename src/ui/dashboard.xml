    <!-- Entry Template: 5-column row (Status, Name, Level, Cost, Value, Profit) -->
    <Button name="ProfitCraftEntryTemplate" virtual="true">
        <Size>
            <AbsDimension x="545" y="22"/>
        </Size>
        <Layers>
            <Layer level="BORDER">
                <FontString name="$parentStatus" inherits="GameFontNormalSmall" justifyH="CENTER" text="">
                    <Size>
                        <AbsDimension x="14" y="22"/>
                    </Size>
                    <Anchors>
                        <Anchor point="LEFT">
                            <Offset>
                                <AbsDimension x="0" y="0"/>
                            </Offset>
                        </Anchor>
                    </Anchors>
                </FontString>
                <FontString name="$parentName" inherits="GameFontNormal" justifyH="LEFT" text="">
                    <Size>
                        <AbsDimension x="190" y="22"/>
                    </Size>
                    <Anchors>
                        <Anchor point="LEFT">
                            <Offset>
                                <AbsDimension x="16" y="0"/>
                            </Offset>
                        </Anchor>
                    </Anchors>
                </FontString>
                <FontString name="$parentLevel" inherits="GameFontHighlightSmall" justifyH="RIGHT" text="">
                    <Size>
                        <AbsDimension x="50" y="22"/>
                    </Size>
                    <Anchors>
                        <Anchor point="LEFT">
                            <Offset>
                                <AbsDimension x="208" y="0"/>
                            </Offset>
                        </Anchor>
                    </Anchors>
                </FontString>
                <FontString name="$parentCost" inherits="GameFontHighlightSmall" justifyH="RIGHT" text="">
                    <Size>
                        <AbsDimension x="94" y="22"/>
                    </Size>
                    <Anchors>
                        <Anchor point="LEFT">
                            <Offset>
                                <AbsDimension x="260" y="0"/>
                            </Offset>
                        </Anchor>
                    </Anchors>
                </FontString>
                <FontString name="$parentValue" inherits="GameFontHighlightSmall" justifyH="RIGHT" text="">
                    <Size>
                        <AbsDimension x="94" y="22"/>
                    </Size>
                    <Anchors>
                        <Anchor point="LEFT">
                            <Offset>
                                <AbsDimension x="356" y="0"/>
                            </Offset>
                        </Anchor>
                    </Anchors>
                </FontString>
                <FontString name="$parentProfit" inherits="GameFontHighlightSmall" justifyH="RIGHT" text="">
                    <Size>
                        <AbsDimension x="90" y="22"/>
                    </Size>
                    <Anchors>
                        <Anchor point="RIGHT">
                            <Offset>
                                <AbsDimension x="-2" y="0"/>
                            </Offset>
                        </Anchor>
                    </Anchors>
                </FontString>
            </Layer>
        </Layers>
        <HighlightTexture file="Interface\QuestFrame\UI-QuestTitleHighlight" alphaMode="ADD"/>
        <Scripts>
            <OnClick>
                ProfitCraft_OnEntryClick(this);
            </OnClick>
            <OnEnter>
                ProfitCraft_OnEntryEnter(this);
            </OnEnter>
            <OnLeave>
                GameTooltip:Hide();
            </OnLeave>
        </Scripts>
    </Button>

    <!-- Main Dashboard Frame -->
