                </Anchors>
                <Layers>
                    <Layer level="ARTWORK">
                        <Texture>
                            <Color r="0.35" g="0.33" b="0.3" a="0.8"/>
                        </Texture>
                    </Layer>
                </Layers>
            </Frame>

            <!-- ============ Recipe Detail Pane ============ -->
            <Frame name="ProfitCraftTracker">
                <Size>
                    <AbsDimension x="570" y="220" />
                </Size>
                <Anchors>
                    <Anchor point="TOPLEFT" relativeTo="ProfitCraftDashboard">
                        <Offset>
                            <AbsDimension x="22" y="-330"/>
                        </Offset>
                    </Anchor>
                </Anchors>
                <Layers>
                    <Layer level="ARTWORK">
                        <FontString name="ProfitCraftTrackerTitle" inherits="GameFontNormal" text="Recipe Details" justifyH="LEFT">
                            <Anchors>
                                <Anchor point="TOPLEFT">
                                    <Offset>
                                        <AbsDimension x="0" y="0"/>
                                    </Offset>
                                </Anchor>
                            </Anchors>
                        </FontString>
                    </Layer>
                </Layers>
                <Frames>
                    <Button name="ProfitCraftTrackerAddButton" inherits="UIPanelButtonTemplate" text="Add">
                        <Size>
                            <AbsDimension x="80" y="22"/>
                        </Size>
                        <Anchors>
                            <Anchor point="TOPRIGHT" relativeTo="ProfitCraftTracker">
                                <Offset>
                                    <AbsDimension x="-6" y="-2"/>
                                </Offset>
                            </Anchor>
                        </Anchors>
                        <NormalFont inherits="GameFontHighlightSmall"/>
                        <HighlightFont inherits="GameFontHighlightSmall"/>
                        <DisabledFont inherits="GameFontDisableSmall"/>
                        <Scripts>
                            <OnClick>ProfitCraft_AddSelectedRecipeToShoppingList();</OnClick>
                        </Scripts>
                    </Button>
                    <Button name="ProfitCraftTrackerRemoveButton" inherits="UIPanelButtonTemplate" text="Remove">
                        <Size>
                            <AbsDimension x="80" y="22"/>
                        </Size>
                        <Anchors>
                            <Anchor point="RIGHT" relativeTo="ProfitCraftTrackerAddButton" relativePoint="LEFT">
                                <Offset>
                                    <AbsDimension x="-4" y="0"/>
                                </Offset>
                            </Anchor>
                        </Anchors>
                        <NormalFont inherits="GameFontHighlightSmall"/>
                        <HighlightFont inherits="GameFontHighlightSmall"/>
                        <DisabledFont inherits="GameFontDisableSmall"/>
                        <Scripts>
                            <OnClick>ProfitCraft_RemoveSelectedRecipeFromShoppingList();</OnClick>
                        </Scripts>
                    </Button>
                    <Button name="ProfitCraftTrackerSearchItemButton" inherits="UIPanelButtonTemplate" text="Search">
                        <Size>
                            <AbsDimension x="70" y="22"/>
                        </Size>
                        <Anchors>
                            <Anchor point="RIGHT" relativeTo="ProfitCraftTrackerRemoveButton" relativePoint="LEFT">
                                <Offset>
                                    <AbsDimension x="-4" y="0"/>
                                </Offset>
                            </Anchor>
                        </Anchors>
                        <NormalFont inherits="GameFontHighlightSmall"/>
                        <HighlightFont inherits="GameFontHighlightSmall"/>
                        <DisabledFont inherits="GameFontDisableSmall"/>
                        <Scripts>
                            <OnClick>ProfitCraft_SearchSelectedRecipeInAux();</OnClick>
                        </Scripts>
                    </Button>
                    <Button name="ProfitCraftTrackerMinus">
                        <Size>
                            <AbsDimension x="22" y="22"/>
                        </Size>
                        <Anchors>
                            <Anchor point="TOPRIGHT" relativeTo="ProfitCraftTracker">
                                <Offset>
                                    <AbsDimension x="-50" y="0"/>
                                </Offset>
                            </Anchor>
                        </Anchors>
                        <NormalTexture file="Interface\Buttons\UI-MinusButton-Up"/>
                        <PushedTexture file="Interface\Buttons\UI-MinusButton-Down"/>
                        <HighlightTexture file="Interface\Buttons\UI-PlusButton-Hilight" alphaMode="ADD"/>
                        <Scripts>
                            <OnClick>ProfitCraft_TrackerAdjustQty(-1);</OnClick>
                        </Scripts>
                    </Button>
                    <Button name="ProfitCraftTrackerPlus">
                        <Size>
                            <AbsDimension x="22" y="22"/>
                        </Size>
                        <Anchors>
                            <Anchor point="LEFT" relativeTo="ProfitCraftTrackerMinus" relativePoint="RIGHT">
                                <Offset>
                                    <AbsDimension x="24" y="0"/>
                                </Offset>
                            </Anchor>
                        </Anchors>
                        <NormalTexture file="Interface\Buttons\UI-PlusButton-Up"/>
                        <PushedTexture file="Interface\Buttons\UI-PlusButton-Down"/>
                        <HighlightTexture file="Interface\Buttons\UI-PlusButton-Hilight" alphaMode="ADD"/>
                        <Scripts>
                            <OnClick>ProfitCraft_TrackerAdjustQty(1);</OnClick>
                        </Scripts>
                    </Button>
                </Frames>
            </Frame>
        </Frames>

        <!-- Scripts -->
        <Scripts>
            <OnLoad>
                this:RegisterForDrag("LeftButton");
                ProfitCraft_Dashboard_OnLoad(this);
            </OnLoad>
            <OnDragStart>
                this:StartMoving();
            </OnDragStart>
            <OnDragStop>
                this:StopMovingOrSizing();
            </OnDragStop>
            <OnHide>
                this:StopMovingOrSizing();
            </OnHide>
        </Scripts>
    </Frame>
</Ui>
