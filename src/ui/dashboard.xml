<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/ ..\FrameXML\UI.xsd">

    <!-- Entry Template: 4-column row (Status, Name, Cost, Value, Profit) -->
    <Button name="ProfitCraftEntryTemplate" virtual="true">
        <Size>
            <AbsDimension x="545" y="22"/>
        </Size>
        <Layers>
            <Layer level="BORDER">
                <FontString name="$parentStatus" inherits="GameFontNormalSmall" justifyH="CENTER" text="">
                    <Size>
                        <AbsDimension x="14" y="22"/>
                    </Size>
                    <Anchors>
                        <Anchor point="LEFT">
                            <Offset>
                                <AbsDimension x="0" y="0"/>
                            </Offset>
                        </Anchor>
                    </Anchors>
                </FontString>
                <FontString name="$parentName" inherits="GameFontNormal" justifyH="LEFT" text="">
                    <Size>
                        <AbsDimension x="220" y="22"/>
                    </Size>
                    <Anchors>
                        <Anchor point="LEFT">
                            <Offset>
                                <AbsDimension x="16" y="0"/>
                            </Offset>
                        </Anchor>
                    </Anchors>
                </FontString>
                <FontString name="$parentCost" inherits="GameFontHighlightSmall" justifyH="RIGHT" text="">
                    <Size>
                        <AbsDimension x="110" y="22"/>
                    </Size>
                    <Anchors>
                        <Anchor point="LEFT">
                            <Offset>
                                <AbsDimension x="238" y="0"/>
                            </Offset>
                        </Anchor>
                    </Anchors>
                </FontString>
                <FontString name="$parentValue" inherits="GameFontHighlightSmall" justifyH="RIGHT" text="">
                    <Size>
                        <AbsDimension x="110" y="22"/>
                    </Size>
                    <Anchors>
                        <Anchor point="LEFT">
                            <Offset>
                                <AbsDimension x="350" y="0"/>
                            </Offset>
                        </Anchor>
                    </Anchors>
                </FontString>
                <FontString name="$parentProfit" inherits="GameFontHighlightSmall" justifyH="RIGHT" text="">
                    <Size>
                        <AbsDimension x="90" y="22"/>
                    </Size>
                    <Anchors>
                        <Anchor point="RIGHT">
                            <Offset>
                                <AbsDimension x="-2" y="0"/>
                            </Offset>
                        </Anchor>
                    </Anchors>
                </FontString>
            </Layer>
        </Layers>
        <HighlightTexture file="Interface\QuestFrame\UI-QuestTitleHighlight" alphaMode="ADD"/>
        <Scripts>
            <OnClick>
                ProfitCraft_OnEntryClick(this);
            </OnClick>
            <OnEnter>
                ProfitCraft_OnEntryEnter(this);
            </OnEnter>
            <OnLeave>
                GameTooltip:Hide();
            </OnLeave>
        </Scripts>
    </Button>

    <!-- Main Dashboard Frame -->
    <Frame name="ProfitCraftDashboard" parent="UIParent" hidden="true" toplevel="true" enableMouse="true" movable="true">
        <Size>
            <AbsDimension x="620" y="580" />
        </Size>
        <Anchors>
            <Anchor point="CENTER" />
        </Anchors>
        <Backdrop bgFile="Interface\DialogFrame\UI-DialogBox-Background" edgeFile="Interface\DialogFrame\UI-DialogBox-Border" tile="true">
            <BackgroundInsets>
                <AbsInset left="11" right="12" top="12" bottom="11" />
            </BackgroundInsets>
            <TileSize>
                <AbsValue val="32" />
            </TileSize>
            <EdgeSize>
                <AbsValue val="32" />
            </EdgeSize>
        </Backdrop>

        <!-- Header -->
        <Layers>
            <Layer level="ARTWORK">
                <Texture name="$parentHeader" file="Interface\DialogFrame\UI-DialogBox-Header">
                    <Size>
                        <AbsDimension x="300" y="64" />
                    </Size>
                    <Anchors>
                        <Anchor point="TOP">
                            <Offset>
                                <AbsDimension x="0" y="12" />
                            </Offset>
                        </Anchor>
                    </Anchors>
                </Texture>
                <FontString name="$parentTitleText" inherits="GameFontNormal" text="ProfitCraft Dashboard">
                    <Anchors>
                        <Anchor point="TOP" relativeTo="$parentHeader">
                            <Offset>
                                <AbsDimension x="0" y="-14" />
                            </Offset>
                        </Anchor>
                    </Anchors>
                </FontString>
            </Layer>
        </Layers>

        <Frames>
            <!-- Close Button -->
            <Button name="$parentCloseButton" inherits="UIPanelCloseButton">
                <Anchors>
                    <Anchor point="TOPRIGHT">
                        <Offset>
                            <AbsDimension x="-3" y="-3" />
                        </Offset>
                    </Anchor>
                </Anchors>
            </Button>

            <Button name="ProfitCraftSettingsToggle">
                <Size>
                    <AbsDimension x="92" y="18"/>
                </Size>
                <Anchors>
                    <Anchor point="TOPRIGHT" relativeTo="ProfitCraftDashboard">
                        <Offset>
                            <AbsDimension x="-36" y="-8"/>
                        </Offset>
                    </Anchor>
                </Anchors>
                <NormalTexture file="Interface\FriendsFrame\WhoFrame-ColumnHead"/>
                <HighlightTexture file="Interface\PaperDollInfoFrame\UI-Character-Tab-Highlight" alphaMode="ADD"/>
                <NormalFont inherits="GameFontHighlightSmall"/>
                <NormalText text="Settings"/>
                <Scripts>
                    <OnClick>ProfitCraft_ToggleSettings();</OnClick>
                </Scripts>
            </Button>

            <Frame name="ProfitCraftSettingsPanel" hidden="true" enableMouse="true" toplevel="true" frameStrata="DIALOG">
                <Size>
                    <AbsDimension x="250" y="176"/>
                </Size>
                <Anchors>
                    <Anchor point="TOPRIGHT" relativeTo="ProfitCraftDashboard">
                        <Offset>
                            <AbsDimension x="-24" y="-52"/>
                        </Offset>
                    </Anchor>
                </Anchors>
                <Backdrop bgFile="Interface\Tooltips\UI-Tooltip-Background" edgeFile="Interface\Tooltips\UI-Tooltip-Border" tile="true">
                    <BackgroundInsets>
                        <AbsInset left="3" right="3" top="3" bottom="3"/>
                    </BackgroundInsets>
                    <TileSize>
                        <AbsValue val="16"/>
                    </TileSize>
                    <EdgeSize>
                        <AbsValue val="12"/>
                    </EdgeSize>
                    <BackdropColor r="0.06" g="0.06" b="0.06" a="0.92"/>
                    <BackdropBorderColor r="0.75" g="0.75" b="0.75" a="1.0"/>
                </Backdrop>
                <Layers>
                    <Layer level="OVERLAY">
                        <FontString name="ProfitCraftSettingsTitle" inherits="GameFontNormalSmall" text="Settings" justifyH="LEFT">
                            <Anchors>
                                <Anchor point="TOPLEFT" relativeTo="ProfitCraftSettingsPanel">
                                    <Offset>
                                        <AbsDimension x="10" y="-10"/>
                                    </Offset>
                                </Anchor>
                            </Anchors>
                        </FontString>
                    </Layer>
                </Layers>
                <Frames>
                    <CheckButton name="ProfitCraftSettingShowQuest" inherits="UICheckButtonTemplate">
                        <Size>
                            <AbsDimension x="24" y="24"/>
                        </Size>
                        <Anchors>
                            <Anchor point="TOPLEFT" relativeTo="ProfitCraftSettingsPanel">
                                <Offset>
                                    <AbsDimension x="8" y="-24"/>
                                </Offset>
                            </Anchor>
                        </Anchors>
                        <Scripts>
                            <OnClick>ProfitCraft_OnSettingToggle("showQuest");</OnClick>
                        </Scripts>
                    </CheckButton>
                    <CheckButton name="ProfitCraftSettingShowTrainer" inherits="UICheckButtonTemplate">
                        <Size>
                            <AbsDimension x="24" y="24"/>
                        </Size>
                        <Anchors>
                            <Anchor point="TOPLEFT" relativeTo="ProfitCraftSettingsPanel">
                                <Offset>
                                    <AbsDimension x="8" y="-44"/>
                                </Offset>
                            </Anchor>
                        </Anchors>
                        <Scripts>
                            <OnClick>ProfitCraft_OnSettingToggle("showTrainer");</OnClick>
                        </Scripts>
                    </CheckButton>
                    <CheckButton name="ProfitCraftSettingShowVendor" inherits="UICheckButtonTemplate">
                        <Size>
                            <AbsDimension x="24" y="24"/>
                        </Size>
                        <Anchors>
                            <Anchor point="TOPLEFT" relativeTo="ProfitCraftSettingsPanel">
                                <Offset>
                                    <AbsDimension x="8" y="-64"/>
                                </Offset>
                            </Anchor>
                        </Anchors>
                        <Scripts>
                            <OnClick>ProfitCraft_OnSettingToggle("showVendor");</OnClick>
                        </Scripts>
                    </CheckButton>
                    <CheckButton name="ProfitCraftSettingShowDrop" inherits="UICheckButtonTemplate">
                        <Size>
                            <AbsDimension x="24" y="24"/>
                        </Size>
                        <Anchors>
                            <Anchor point="TOPLEFT" relativeTo="ProfitCraftSettingsPanel">
                                <Offset>
                                    <AbsDimension x="8" y="-84"/>
                                </Offset>
                            </Anchor>
                        </Anchors>
                        <Scripts>
                            <OnClick>ProfitCraft_OnSettingToggle("showDrop");</OnClick>
                        </Scripts>
                    </CheckButton>
                    <CheckButton name="ProfitCraftSettingAutoMerchant" inherits="UICheckButtonTemplate">
                        <Size>
                            <AbsDimension x="24" y="24"/>
                        </Size>
                        <Anchors>
                            <Anchor point="TOPLEFT" relativeTo="ProfitCraftSettingsPanel">
                                <Offset>
                                    <AbsDimension x="8" y="-104"/>
                                </Offset>
                            </Anchor>
                        </Anchors>
                        <Scripts>
                            <OnClick>ProfitCraft_OnSettingToggle("autoOpenMerchant");</OnClick>
                        </Scripts>
                    </CheckButton>
                    <CheckButton name="ProfitCraftSettingAutoAuction" inherits="UICheckButtonTemplate">
                        <Size>
                            <AbsDimension x="24" y="24"/>
                        </Size>
                        <Anchors>
                            <Anchor point="TOPLEFT" relativeTo="ProfitCraftSettingsPanel">
                                <Offset>
                                    <AbsDimension x="8" y="-124"/>
                                </Offset>
                            </Anchor>
                        </Anchors>
                        <Scripts>
                            <OnClick>ProfitCraft_OnSettingToggle("autoOpenAuction");</OnClick>
                        </Scripts>
                    </CheckButton>
                    <CheckButton name="ProfitCraftSettingAutoShoppingOnly" inherits="UICheckButtonTemplate">
                        <Size>
                            <AbsDimension x="24" y="24"/>
                        </Size>
                        <Anchors>
                            <Anchor point="TOPLEFT" relativeTo="ProfitCraftSettingsPanel">
                                <Offset>
                                    <AbsDimension x="8" y="-144"/>
                                </Offset>
                            </Anchor>
                        </Anchors>
                        <Scripts>
                            <OnClick>ProfitCraft_OnSettingToggle("autoOpenShoppingOnly");</OnClick>
                        </Scripts>
                    </CheckButton>
                </Frames>
            </Frame>

            <!-- ============ Filter Bar ============ -->
            <Frame name="ProfitCraftFilterBar">
                <Size>
                    <AbsDimension x="550" y="26" />
                </Size>
                <Anchors>
                    <Anchor point="TOPLEFT" relativeTo="ProfitCraftDashboard">
                        <Offset>
                            <AbsDimension x="24" y="-28" />
                        </Offset>
                    </Anchor>
                </Anchors>
                <Frames>
                    <!-- Learned checkbox at x=0 -->
                    <CheckButton name="ProfitCraftFilterLearned" inherits="UICheckButtonTemplate">
                        <Size>
                            <AbsDimension x="24" y="24"/>
                        </Size>
                        <Anchors>
                            <Anchor point="TOPLEFT" relativeTo="ProfitCraftFilterBar">
                                <Offset>
                                    <AbsDimension x="0" y="-1"/>
                                </Offset>
                            </Anchor>
                        </Anchors>
                        <Scripts>
                            <OnClick>
                                ProfitCraft_OnFilterChanged();
                            </OnClick>
                        </Scripts>
                    </CheckButton>
                    <!-- Unlearned checkbox at x=130 -->
                    <CheckButton name="ProfitCraftFilterUnlearned" inherits="UICheckButtonTemplate">
                        <Size>
                            <AbsDimension x="24" y="24"/>
                        </Size>
                        <Anchors>
                            <Anchor point="TOPLEFT" relativeTo="ProfitCraftFilterBar">
                                <Offset>
                                    <AbsDimension x="130" y="-1"/>
                                </Offset>
                            </Anchor>
                        </Anchors>
                        <Scripts>
                            <OnClick>
                                ProfitCraft_OnFilterChanged();
                            </OnClick>
                        </Scripts>
                    </CheckButton>
                    <!-- Quest checkbox at x=280 -->
                    <CheckButton name="ProfitCraftFilterQuest" inherits="UICheckButtonTemplate">
                        <Size>
                            <AbsDimension x="24" y="24"/>
                        </Size>
                        <Anchors>
                            <Anchor point="TOPLEFT" relativeTo="ProfitCraftFilterBar">
                                <Offset>
                                    <AbsDimension x="280" y="-1"/>
                                </Offset>
                            </Anchor>
                        </Anchors>
                        <Scripts>
                            <OnClick>
                                ProfitCraft_OnFilterChanged();
                            </OnClick>
                        </Scripts>
                    </CheckButton>
                    <!-- Shopping-only checkbox at x=380 -->
                    <CheckButton name="ProfitCraftFilterShoppingOnly" inherits="UICheckButtonTemplate">
                        <Size>
                            <AbsDimension x="24" y="24"/>
                        </Size>
                        <Anchors>
                            <Anchor point="TOPLEFT" relativeTo="ProfitCraftFilterBar">
                                <Offset>
                                    <AbsDimension x="380" y="-1"/>
                                </Offset>
                            </Anchor>
                        </Anchors>
                        <Scripts>
                            <OnClick>
                                ProfitCraft_OnFilterChanged();
                            </OnClick>
                        </Scripts>
                    </CheckButton>
                </Frames>
            </Frame>

            <!-- ============ Column Headers ============ -->
            <Frame name="ProfitCraftColumnHeaders">
                <Size>
                    <AbsDimension x="560" y="18"/>
                </Size>
                <Anchors>
                    <Anchor point="TOPLEFT" relativeTo="ProfitCraftDashboard">
                        <Offset>
                            <AbsDimension x="22" y="-56"/>
                        </Offset>
                    </Anchor>
                </Anchors>
                <Frames>
                    <Button name="ProfitCraftHeaderName">
                        <Size>
                            <AbsDimension x="236" y="18"/>
                        </Size>
                        <Anchors>
                            <Anchor point="LEFT">
                                <Offset>
                                    <AbsDimension x="0" y="0"/>
                                </Offset>
                            </Anchor>
                        </Anchors>
                        <NormalTexture file="Interface\FriendsFrame\WhoFrame-ColumnHead"/>
                        <HighlightTexture file="Interface\PaperDollInfoFrame\UI-Character-Tab-Highlight" alphaMode="ADD"/>
                        <NormalFont inherits="GameFontHighlightSmall"/>
                        <NormalText text="  Recipe Name"/>
                        <Scripts>
                            <OnClick>ProfitCraft_SortBy("name");</OnClick>
                        </Scripts>
                    </Button>
                    <Button name="ProfitCraftHeaderCost">
                        <Size>
                            <AbsDimension x="112" y="18"/>
                        </Size>
                        <Anchors>
                            <Anchor point="LEFT" relativeTo="ProfitCraftHeaderName" relativePoint="RIGHT"/>
                        </Anchors>
                        <NormalTexture file="Interface\FriendsFrame\WhoFrame-ColumnHead"/>
                        <HighlightTexture file="Interface\PaperDollInfoFrame\UI-Character-Tab-Highlight" alphaMode="ADD"/>
                        <NormalFont inherits="GameFontHighlightSmall"/>
                        <NormalText text="Craft Cost"/>
                        <Scripts>
                            <OnClick>ProfitCraft_SortBy("cost");</OnClick>
                        </Scripts>
                    </Button>
                    <Button name="ProfitCraftHeaderValue">
                        <Size>
                            <AbsDimension x="112" y="18"/>
                        </Size>
                        <Anchors>
                            <Anchor point="LEFT" relativeTo="ProfitCraftHeaderCost" relativePoint="RIGHT"/>
                        </Anchors>
                        <NormalTexture file="Interface\FriendsFrame\WhoFrame-ColumnHead"/>
                        <HighlightTexture file="Interface\PaperDollInfoFrame\UI-Character-Tab-Highlight" alphaMode="ADD"/>
                        <NormalFont inherits="GameFontHighlightSmall"/>
                        <NormalText text="Market Value"/>
                        <Scripts>
                            <OnClick>ProfitCraft_SortBy("marketValue");</OnClick>
                        </Scripts>
                    </Button>
                    <Button name="ProfitCraftHeaderProfit">
                        <Size>
                            <AbsDimension x="92" y="18"/>
                        </Size>
                        <Anchors>
                            <Anchor point="LEFT" relativeTo="ProfitCraftHeaderValue" relativePoint="RIGHT"/>
                        </Anchors>
                        <NormalTexture file="Interface\FriendsFrame\WhoFrame-ColumnHead"/>
                        <HighlightTexture file="Interface\PaperDollInfoFrame\UI-Character-Tab-Highlight" alphaMode="ADD"/>
                        <NormalFont inherits="GameFontHighlightSmall"/>
                        <NormalText text="Profit"/>
                        <Scripts>
                            <OnClick>ProfitCraft_SortBy("profit");</OnClick>
                        </Scripts>
                    </Button>
                </Frames>
            </Frame>

            <!-- ============ Scrollable List ============ -->
            <ScrollFrame name="ProfitCraftDashboardScrollFrame" inherits="FauxScrollFrameTemplate">
                <Size>
                    <AbsDimension x="555" y="242"/>
                </Size>
                <Anchors>
                    <Anchor point="TOPLEFT" relativeTo="ProfitCraftDashboard">
                        <Offset>
                            <AbsDimension x="22" y="-76"/>
                        </Offset>
                    </Anchor>
                </Anchors>
                <Scripts>
                    <OnVerticalScroll>
                        FauxScrollFrame_OnVerticalScroll(22, ProfitCraft_DashboardUpdate);
                    </OnVerticalScroll>
                </Scripts>
            </ScrollFrame>

            <!-- ============ Separator ============ -->
            <Frame name="ProfitCraftSeparator">
                <Size>
                    <AbsDimension x="570" y="2"/>
                </Size>
                <Anchors>
                    <Anchor point="TOPLEFT" relativeTo="ProfitCraftDashboard">
                        <Offset>
                            <AbsDimension x="22" y="-324"/>
                        </Offset>
                    </Anchor>
                </Anchors>
                <Layers>
                    <Layer level="ARTWORK">
                        <Texture>
                            <Color r="0.5" g="0.5" b="0.5" a="0.6"/>
                        </Texture>
                    </Layer>
                </Layers>
            </Frame>

            <!-- ============ Recipe Detail Pane ============ -->
            <Frame name="ProfitCraftTracker">
                <Size>
                    <AbsDimension x="570" y="220" />
                </Size>
                <Anchors>
                    <Anchor point="TOPLEFT" relativeTo="ProfitCraftDashboard">
                        <Offset>
                            <AbsDimension x="22" y="-330"/>
                        </Offset>
                    </Anchor>
                </Anchors>
                <Layers>
                    <Layer level="ARTWORK">
                        <FontString name="ProfitCraftTrackerTitle" inherits="GameFontNormal" text="Recipe Details" justifyH="LEFT">
                            <Anchors>
                                <Anchor point="TOPLEFT">
                                    <Offset>
                                        <AbsDimension x="0" y="0"/>
                                    </Offset>
                                </Anchor>
                            </Anchors>
                        </FontString>
                    </Layer>
                </Layers>
                <Frames>
                    <Button name="ProfitCraftTrackerAddButton" inherits="UIPanelButtonTemplate" text="Add to Shopping">
                        <Size>
                            <AbsDimension x="140" y="20"/>
                        </Size>
                        <Anchors>
                            <Anchor point="TOPRIGHT" relativeTo="ProfitCraftTracker">
                                <Offset>
                                    <AbsDimension x="-6" y="2"/>
                                </Offset>
                            </Anchor>
                        </Anchors>
                        <Scripts>
                            <OnClick>ProfitCraft_AddSelectedRecipeToShoppingList();</OnClick>
                        </Scripts>
                    </Button>
                    <Button name="ProfitCraftTrackerMinus">
                        <Size>
                            <AbsDimension x="22" y="22"/>
                        </Size>
                        <Anchors>
                            <Anchor point="TOPRIGHT" relativeTo="ProfitCraftTracker">
                                <Offset>
                                    <AbsDimension x="-50" y="0"/>
                                </Offset>
                            </Anchor>
                        </Anchors>
                        <NormalTexture file="Interface\Buttons\UI-MinusButton-Up"/>
                        <PushedTexture file="Interface\Buttons\UI-MinusButton-Down"/>
                        <HighlightTexture file="Interface\Buttons\UI-PlusButton-Hilight" alphaMode="ADD"/>
                        <Scripts>
                            <OnClick>ProfitCraft_TrackerAdjustQty(-1);</OnClick>
                        </Scripts>
                    </Button>
                    <Button name="ProfitCraftTrackerPlus">
                        <Size>
                            <AbsDimension x="22" y="22"/>
                        </Size>
                        <Anchors>
                            <Anchor point="LEFT" relativeTo="ProfitCraftTrackerMinus" relativePoint="RIGHT">
                                <Offset>
                                    <AbsDimension x="24" y="0"/>
                                </Offset>
                            </Anchor>
                        </Anchors>
                        <NormalTexture file="Interface\Buttons\UI-PlusButton-Up"/>
                        <PushedTexture file="Interface\Buttons\UI-PlusButton-Down"/>
                        <HighlightTexture file="Interface\Buttons\UI-PlusButton-Hilight" alphaMode="ADD"/>
                        <Scripts>
                            <OnClick>ProfitCraft_TrackerAdjustQty(1);</OnClick>
                        </Scripts>
                    </Button>
                </Frames>
            </Frame>
        </Frames>

        <!-- Scripts -->
        <Scripts>
            <OnLoad>
                this:RegisterForDrag("LeftButton");
                ProfitCraft_Dashboard_OnLoad(this);
            </OnLoad>
            <OnDragStart>
                this:StartMoving();
            </OnDragStart>
            <OnDragStop>
                this:StopMovingOrSizing();
            </OnDragStop>
            <OnHide>
                this:StopMovingOrSizing();
            </OnHide>
        </Scripts>
    </Frame>
</Ui>
